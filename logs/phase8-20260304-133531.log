+	unsubB()
+	w.Notify(3)
+
+	time.Sleep(20 * time.Millisecond)
+
+	mu.Lock()
+	defer mu.Unlock()
+	if len(got) != 3 {
+		t.Fatalf("expected 3 notifications, got %d (%v)", len(got), got)
+	}
+}
+
+func TestWorkerRestartHoldoff(t *testing.T) {
+	w := newTestWorker("restart-worker")
+	defer w.Shutdown()
