+	w.handlersMu.Lock()
+	id := w.nextHandlerID
+	w.nextHandlerID++
+	w.handlers[id] = handler
+	w.handlersMu.Unlock()
+
+	var once sync.Once
+	return func() {
+		once.Do(func() {
+			w.handlersMu.Lock()
+			delete(w.handlers, id)
+			w.handlersMu.Unlock()
+		})
+	}
