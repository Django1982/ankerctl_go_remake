+	runCount := w.runCount
+	restartOn := w.restartOn
+	w.mu.Unlock()
+
+	if runCount == restartOn {
+		return ErrServiceRestartSignal
+	}
+
+	select {
+	case <-ctx.Done():
+		return nil
+	case <-time.After(50 * time.Millisecond):
+		return nil
+	}
+}
