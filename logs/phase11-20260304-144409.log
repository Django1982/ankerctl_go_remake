		}
		profile = strings.ToLower(strings.TrimSpace(profile))
		if profile != "sd" && profile != "hd" && profile != "fhd" {
			return map[string]any{"error": "video_profile value must be sd|hd|fhd"}
		}
		svc, err := h.services.Borrow("videoqueue")
		if err != nil {
