#!/bin/sh
# Prevents direct commits to the main branch.
# Merge commits (MERGE_HEAD exists) are allowed since they are part of the
# sanctioned feature-branch workflow.
# Install via: scripts/install-hooks.sh

branch=$(git symbolic-ref HEAD 2>/dev/null)
if [ "$branch" = "refs/heads/main" ] && [ ! -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]; then
  echo "ERROR: Direct commits to main are forbidden."
  echo "Create a feature branch first: git checkout -b <branch-name>"
  exit 1
fi
